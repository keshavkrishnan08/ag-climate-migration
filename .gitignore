# ============================================================
# AgMigration .gitignore
#
# Structure:
#   GitHub repo  = code + paper + published dataset
#   Zenodo       = full dataset tarball (gets DOI)
#   Raw data     = not tracked (too large, publicly available)
#   Results      = not tracked (regenerated by `make all`)
# ============================================================

# ------ Raw and intermediate data (large, publicly available) ------
data/raw/
data/processed/
data/projections/

# ------ Results (regenerated by pipeline) ------
results/
models/

# ------ Published dataset: track the README and datasheet, not CSVs ------
# CSVs go to Zenodo. README and datasheet are small enough for git.
data/published_dataset/*.csv
data/published_dataset/*.tar.gz

# ------ Pipeline state (regenerated) ------
state/bus/
state/checkpoints/
logs/

# ------ Paper build artifacts ------
paper/*.aux
paper/*.log
paper/*.bbl
paper/*.blg
paper/*.out
paper/*.toc
paper/*.fdb_latexmk
paper/*.fls
paper/*.synctex.gz
paper/missfont.log

# ------ Track paper PDFs (needed for submission) ------
# NOTE: main.pdf, cover_letter.pdf, supplementary_information.pdf
# are NOT ignored — they should be committed for submission.

# ------ Python ------
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
dist/
build/
*.egg

# ------ Environment and secrets ------
.env
*.env
*.api_key
.env.local

# ------ Virtual environments ------
venv/
.venv/
env/

# ------ IDE ------
.vscode/
.idea/
*.swp
*.swo
*~

# ------ OS ------
.DS_Store
Thumbs.db
ehthumbs.db

# ------ Jupyter ------
.ipynb_checkpoints/

# ------ Large model files (regenerated by training) ------
*.pkl
!results/  # already ignored above

# ------ Temporary files ------
*.tmp
*.bak


paper/
submission/
